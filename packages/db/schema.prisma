// Datasource y generador
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BudgetPeriod {
  monthly
}

enum BudgetAlertThreshold {
  eighty
  oneHundred
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  currency     String   @default("EUR")
  createdAt    DateTime @default(now())

  transactions PersonalTransaction[]
  groups       Group[]  @relation("UserGroups")
  memberships  GroupMember[] @relation("UserMember")
  categories   Category[]
  budgets      Budget[]
  pushSubscriptions PushSubscription[]
  budgetAlerts BudgetAlert[]
  subscription Subscription?
}

model Subscription {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  plan             String    @default("free") // 'free' | 'premium'
  status           String    @default("active") // 'active' | 'canceled' | 'past_due'
  provider         String?   // 'stripe' (integración futura)
  providerRef      String?   // id de la suscripción en el proveedor
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  type        String   // 'income' | 'expense'
  color       String?
  icon        String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])
  
  personalTransactions PersonalTransaction[]
  groupExpenses        GroupExpense[]
  budgets              Budget[]

  @@unique([name, userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model PersonalTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])
  type        String
  sourceType  String   @default("manual")
  sourceRefId String?
  locked      Boolean  @default(false)
  amount      Decimal  @db.Decimal(12,2)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  occurredAt  DateTime
  note        String?

  @@index([userId, occurredAt])
  @@index([groupId])
  @@index([sourceType, sourceRefId])
  @@index([categoryId])
  @@unique([userId, sourceType, sourceRefId])
}

model Group {
  id           String   @id @default(uuid())
  name         String
  ownerUserId  String
  owner        User     @relation("UserGroups", fields: [ownerUserId], references: [id])
  currency     String   @default("EUR")
  joinCode     String?  @unique
  createdAt    DateTime @default(now())

  members               GroupMember[]
  expenses              GroupExpense[]
  settlements           GroupSettlement[]
  personalTransactions  PersonalTransaction[]
  categories            Category[]

  @@index([ownerUserId, createdAt])
}

model GroupMember {
  id         String   @id @default(uuid())
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id])
  userId     String?  // null si participante falso
  user       User?    @relation("UserMember", fields: [userId], references: [id])
  displayName String
  weight     Decimal? @db.Decimal(8,4)
  role       String   @default("member") // 'member' | 'admin'
  leftAt     DateTime? // null = activo, set = miembro dado de baja

  expensesAsPayer GroupExpense[] @relation("PayerRelation")
  expensesCreated GroupExpense[] @relation("ExpenseCreator")
  splits          GroupSplit[]
  settlementsFrom GroupSettlement[] @relation("FromMember")
  settlementsTo   GroupSettlement[] @relation("ToMember")

  @@index([groupId])
  @@index([userId])
  @@index([groupId, leftAt])
}

model GroupExpense {
  id            String   @id @default(uuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id])
  payerMemberId String
  payer         GroupMember @relation("PayerRelation", fields: [payerMemberId], references: [id])
  createdByMemberId String?
  createdByMember   GroupMember? @relation("ExpenseCreator", fields: [createdByMemberId], references: [id])
  amount        Decimal  @db.Decimal(12,2)
  description   String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  occurredAt    DateTime
  splitMethod   String   // 'equal' | 'weights'

  splits        GroupSplit[]

  @@index([groupId, occurredAt])
  @@index([payerMemberId])
  @@index([createdByMemberId])
  @@index([categoryId])
}

model GroupSplit {
  id         String   @id @default(uuid())
  expenseId  String
  expense    GroupExpense @relation(fields: [expenseId], references: [id])
  memberId   String
  member     GroupMember  @relation(fields: [memberId], references: [id])
  shareAmount Decimal? @db.Decimal(12,2)
  shareWeight Decimal? @db.Decimal(8,4)

  @@index([expenseId])
  @@index([memberId])
}

model GroupSettlement {
  id            String   @id @default(uuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id])
  fromMemberId  String
  fromMember    GroupMember @relation("FromMember", fields: [fromMemberId], references: [id])
  toMemberId    String
  toMember      GroupMember @relation("ToMember", fields: [toMemberId], references: [id])
  amount        Decimal  @db.Decimal(12,2)
  occurredAt    DateTime
  status        String   @default("proposed") // 'proposed' | 'confirmed' | 'cancelled'

  @@index([groupId, occurredAt])
  @@index([fromMemberId])
  @@index([toMemberId])
}

model IdempotencyRequest {
  id              String   @id @default(uuid())
  userId          String
  endpoint        String
  idempotencyKey  String
  requestHash     String
  responseStatus  Int
  responseBody    Json
  createdAt       DateTime @default(now())

  @@unique([userId, endpoint, idempotencyKey])
  @@index([userId, endpoint])
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  endpoint   String   // URL del servicio push
  p256dh     String   // Clave pública del cliente
  auth       String   // Secreto de autenticación
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
}

model Budget {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id])
  amount     Float
  period     BudgetPeriod
  month      Int
  year       Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  alerts     BudgetAlert[]

  @@unique([userId, categoryId, month, year, period])
  @@index([userId, year, month])
  @@index([categoryId])
}

model BudgetAlert {
  id           String              @id @default(uuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  budgetId     String?
  budget       Budget?             @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  categoryId   String
  month        Int
  year         Int
  threshold    BudgetAlertThreshold
  consumedPercent Float
  spentSnapshot   Float
  budgetAmountSnapshot Float
  channel      String              @default("push")
  sentAt       DateTime            @default(now())

  @@unique([userId, categoryId, month, year, threshold])
  @@index([userId])
  @@index([userId, year, month])
  @@index([categoryId])
  @@index([sentAt])
}
