{
  "name": "finanzas-integradas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "prisma:generate": "npm run prisma:generate --workspace=apps/api",
    "prisma:push": "npm run prisma:db-push --workspace=apps/api",
    "test": "npm run test --workspace=apps/web --workspace=apps/api",
    "test:run": "npm run test:run --workspace=apps/web --workspace=apps/api",
    "test:coverage": "npm run test:coverage --workspace=apps/web --workspace=apps/api",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
