# ============================================
# Variables de entorno para producción
# ============================================
# Copia este archivo como .env en el directorio
# raíz del proyecto (donde está docker-compose.yml)
# ============================================

# ---- Base de datos ----
DATABASE_URL=postgres://app:TU_PASSWORD_SEGURA@db:5432/app

# ---- API ----
NODE_ENV=production
PORT=8080
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_LARGA_Y_ALEATORIA

# ---- Web Push Notifications ----
# Genera nuevas claves con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=COLOCA_AQUI_TU_CLAVE_PUBLICA
VAPID_PRIVATE_KEY=COLOCA_AQUI_TU_CLAVE_PRIVADA
VAPID_MAILTO=mailto:tu-email@tudominio.com

# ---- Frontend ----
VITE_API_URL=https://api.tudominio.com

# ============================================
# Notas de seguridad
# ============================================
# 1. JWT_SECRET: mínimo 32 caracteres, algo como:
#    openssl rand -hex 32
#
# 2. DATABASE_URL: cambia TU_PASSWORD_SEGURA
#    por una contraseña fuerte para PostgreSQL
#
# 3. VAPID_*: genera claves nuevas en producción:
#    cd apps/api && npx web-push generate-vapid-keys
#
# 4. VITE_API_URL: la URL pública de tu API
#    (con HTTPS obligatorio para push notifications)
#
# 5. Este archivo NUNCA debe subirse al repositorio.
#    Ya está en .gitignore.
# ============================================
